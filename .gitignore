data/phrase_*.json
data/phrase_*.npy
data/token_masks_*.json
data/*_train_only*.json
data/V_cultural_*.json

# Precomputed features
*.hdf5

# Config overrides (user-specific)
outputs/
runs/

# Build artifacts
models/ops/*.so
models/ops/build/
models/ops/__pycache__/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
venv/
.env
